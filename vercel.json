{
  "buildCommand": "cd agent-viz && npm install && npm run build",
  "outputDirectory": "agent-viz/dist",
  "rewrites": [
    { "source": "/api/proxy/(.*)", "destination": "/api/proxy" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/audit", "destination": "/api/audit" },
    { "source": "/api/test", "destination": "/api/test" },
    { "source": "/api/slack-run", "destination": "/api/slack-run" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
